{
  "name": "edusphere",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "argon2",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp"
    ]
  },
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* dev",
    "dev:api": "pnpm --filter @edusphere/api dev",
    "dev:web": "pnpm --filter @edusphere/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @edusphere/api db:migrate",
    "db:seed": "pnpm --filter @edusphere/api db:seed",
    "db:studio": "pnpm --filter @edusphere/api db:studio"
  }
}
