generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ PLATFORM (no tenantId) ============

enum TenantStatus {
  trial
  active
  past_due
  suspended
  cancelled
}

model Tenant {
  id          String       @id @default(uuid())
  name        String
  slug        String       @unique
  status      TenantStatus @default(trial)
  planId      String?
  plan        Plan?        @relation(fields: [planId], references: [id])
  trialEndsAt DateTime?
  timezone    String       @default("Asia/Baku")
  currency    String       @default("AZN")
  locale      String       @default("az")
  settings    Json         @default("{}")
  branding    Json         @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  subscriptions Subscription[]
  usageRecords  UsageRecord[]

  @@map("tenants")
}

model Plan {
  id           String   @id @default(uuid())
  code         String   @unique // starter|professional|business|enterprise|custom:*
  name         String
  priceMonthly Int // minor units
  priceYearly  Int
  currency     String   @default("AZN")
  limits       Json // {users, students, teachers, branches, aiRequests, storageMb, apiCalls}
  features     Json // {crm, finance, marketing, ai, lms, hr, payroll, api, whiteLabel, multiBranch, whatsapp, webhooks}
  isCustom     Boolean  @default(false)
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants       Tenant[]
  subscriptions Subscription[]

  @@map("plans")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
}

model Subscription {
  id               String             @id @default(uuid())
  tenantId         String
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id])
  period           String // monthly|yearly
  status           SubscriptionStatus @default(trialing)
  currentPeriodEnd DateTime
  cancelAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  invoices SubscriptionInvoice[]

  @@index([tenantId])
  @@map("subscriptions")
}

model SubscriptionInvoice {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  number         String       @unique
  amount         Int
  currency       String       @default("AZN")
  status         String       @default("open") // draft|open|paid|void|uncollectible
  dueAt          DateTime
  paidAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([subscriptionId, status])
  @@map("subscription_invoices")
}

model UsageRecord {
  id       String   @id @default(uuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  metric   String // users|students|teachers|branches|aiRequests|storageMb|apiCalls
  value    Int
  date     DateTime @db.Date

  @@unique([tenantId, metric, date])
  @@map("usage_records")
}

model PlatformUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String // super_admin|support|finance|analyst
  totpSecret   String?
  status       String    @default("active")
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("platform_users")
}

model FeatureFlag {
  id        String   @id @default(uuid())
  key       String   @unique
  enabled   Boolean  @default(false)
  perTenant Json     @default("{}") // {tenantId: bool}
  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}

model Announcement {
  id         String    @id @default(uuid())
  title      String
  body       String
  audience   Json      @default("{}") // {plans:[], statuses:[]}
  activeFrom DateTime
  activeTo   DateTime?
  createdAt  DateTime  @default(now())

  @@map("announcements")
}

model IntegrationCatalog {
  id       String  @id @default(uuid())
  key      String  @unique
  category String // ai|social|ads|payment|calendar|meeting|storage|communication|sms|automation
  name     String
  logo     String?
  enabled  Boolean @default(false)
  minPlan  String?
  config   Json    @default("{}")

  @@map("integration_catalog")
}

model PlatformAudit {
  id         String   @id @default(uuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  diff       Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@map("audit_platform")
}

// ============ IDENTITY (tenant-scoped) ============

model User {
  id           String    @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarFileId String?
  status       String    @default("active") // active|invited|disabled
  locale       String    @default("az")
  totpSecret   String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  roles         UserRole[]
  notifications Notification[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@map("users")
}

model Role {
  id        String   @id @default(uuid())
  tenantId  String
  key       String // owner|admin|... or custom slug
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  permissions RolePermission[]
  users       UserRole[]

  @@unique([tenantId, key])
  @@map("roles")
}

model RolePermission {
  roleId     String
  role       Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission String

  @@id([roleId, permission])
  @@map("role_permissions")
}

model UserRole {
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId   String
  role     Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  branchId String? // optional branch scoping

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid())
  // No FK: userId references users OR platform_users depending on realm.
  userId    String
  realm     String    @default("tenant") // tenant|platform
  familyId  String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId, familyId])
  @@map("refresh_tokens")
}

model Invitation {
  id         String    @id @default(uuid())
  tenantId   String
  email      String
  roleId     String
  branchId   String?
  tokenHash  String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  invitedBy  String?
  createdAt  DateTime  @default(now())

  @@index([tenantId, email])
  @@map("invitations")
}

model ApiKey {
  id         String    @id @default(uuid())
  tenantId   String
  name       String
  prefix     String    @unique
  keyHash    String
  scopes     String[]
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("api_keys")
}

// ============ ORG (tenant-scoped) ============

model Branch {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  address      String?
  phone        String?
  workingHours Json      @default("{}") // {mon:{from:"09:00",to:"20:00"},...}
  isMain       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  rooms Room[]

  @@index([tenantId])
  @@map("branches")
}

model Room {
  id        String    @id @default(uuid())
  tenantId  String
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id])
  name      String
  number    String?
  capacity  Int
  floor     Int?
  equipment String[]
  status    String    @default("active") // active|maintenance|inactive
  photos    String[] // file ids
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  reservations RoomReservation[]

  @@index([tenantId, branchId])
  @@map("rooms")
}

model RoomReservation {
  id          String   @id @default(uuid())
  tenantId    String
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id])
  title       String
  startAt     DateTime
  endAt       DateTime
  createdById String?
  createdAt   DateTime @default(now())

  @@index([tenantId, roomId, startAt])
  @@map("room_reservations")
}

model Holiday {
  id       String   @id @default(uuid())
  tenantId String
  date     DateTime @db.Date
  name     String
  branchId String?

  @@unique([tenantId, date, branchId])
  @@map("holidays")
}

model Setting {
  tenantId  String
  key       String
  value     Json
  updatedAt DateTime @updatedAt

  @@id([tenantId, key])
  @@map("settings")
}

// ============ EDUCATION (tenant-scoped) ============

model CourseCategory {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  parentId String?

  courses Course[]

  @@index([tenantId])
  @@map("course_categories")
}

enum PricingModel {
  monthly
  course
  lesson
}

model Course {
  id              String          @id @default(uuid())
  tenantId        String
  categoryId      String?
  category        CourseCategory? @relation(fields: [categoryId], references: [id])
  name            String
  level           String?
  description     String?
  pricingModel    PricingModel    @default(monthly)
  price           Int // minor units
  currency        String          @default("AZN")
  durationWeeks   Int?
  defaultCapacity Int             @default(12)
  format          String          @default("offline") // online|offline
  syllabus        Json            @default("[]")
  status          String          @default("active") // active|archived
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  groups Group[]

  @@index([tenantId, status])
  @@map("courses")
}

model Student {
  id          String    @id @default(uuid())
  tenantId    String
  code        String // human-readable, per tenant sequence
  firstName   String
  lastName    String
  phone       String?
  email       String?
  birthDate   DateTime? @db.Date
  gender      String?
  address     String?
  parentName  String?
  parentPhone String?
  leadId      String?
  status      String    @default("active") // active|inactive|graduated|archived
  photoFileId String?
  notes       String?
  branchId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  enrollments GroupStudent[]
  attendance  Attendance[]
  examResults ExamResult[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, branchId])
  @@map("students")
}

model Teacher {
  id             String    @id @default(uuid())
  tenantId       String
  userId         String    @unique
  subjects       String[]
  bio            String?
  hiredAt        DateTime? @db.Date
  workingHours   Json      @default("{}") // {mon:{from,to},...} empty = branch hours
  maxWeeklyHours Int       @default(40)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  rates          TeacherRate[]
  groups         Group[]        @relation("GroupTeacher")
  assistantIn    Group[]        @relation("GroupAssistant")
  lessons        Lesson[]       @relation("LessonTeacher")

  @@index([tenantId])
  @@map("teachers")
}

model TeacherRate {
  id        String   @id @default(uuid())
  tenantId  String
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  type      String // per_lesson|per_student|fixed_monthly|revenue_pct
  amount    Int // minor units or percent*100 for revenue_pct
  courseId  String?
  createdAt DateTime @default(now())

  @@index([tenantId, teacherId])
  @@map("teacher_rates")
}

model Group {
  id            String    @id @default(uuid())
  tenantId      String
  courseId      String
  course        Course    @relation(fields: [courseId], references: [id])
  branchId      String
  teacherId     String?
  teacher       Teacher?  @relation("GroupTeacher", fields: [teacherId], references: [id])
  assistantId   String?
  assistant     Teacher?  @relation("GroupAssistant", fields: [assistantId], references: [id])
  roomId        String?
  name          String
  capacity      Int       @default(12)
  priceOverride Int?
  startDate     DateTime? @db.Date
  endDate       DateTime? @db.Date
  status        String    @default("planned") // planned|active|finished|archived
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  students      GroupStudent[]
  scheduleRules ScheduleRule[]
  lessons       Lesson[]
  exams         Exam[]

  @@index([tenantId, status])
  @@index([tenantId, branchId])
  @@map("groups")
}

model GroupStudent {
  id            String    @id @default(uuid())
  tenantId      String
  groupId       String
  group         Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status        String    @default("active") // active|frozen|finished|dropped
  joinedAt      DateTime  @default(now())
  leftAt        DateTime?
  priceOverride Int?

  @@unique([groupId, studentId])
  @@index([tenantId, studentId])
  @@map("group_students")
}

enum LessonType {
  offline
  online
  hybrid
}

model ScheduleRule {
  id         String     @id @default(uuid())
  tenantId   String
  groupId    String
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  weekdays   Int[] // 0=Mon .. 6=Sun
  startTime  String // "18:00"
  endTime    String // "19:30"
  roomId     String?
  teacherId  String?
  type       LessonType @default(offline)
  validFrom  DateTime   @db.Date
  validUntil DateTime?  @db.Date
  createdAt  DateTime   @default(now())

  lessons Lesson[]

  @@index([tenantId, groupId])
  @@map("schedule_rules")
}

model Lesson {
  id              String        @id @default(uuid())
  tenantId        String
  groupId         String
  group           Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ruleId          String?
  rule            ScheduleRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  teacherId       String
  teacherRef      Teacher       @relation("LessonTeacher", fields: [teacherId], references: [id])
  assistantId     String?
  roomId          String?
  date            DateTime      @db.Date
  startAt         DateTime
  endAt           DateTime
  type            LessonType    @default(offline)
  status          String        @default("scheduled") // scheduled|done|cancelled
  cancelReason    String?
  topic           String?
  homework        String?
  journalNotes    String?
  maxParticipants Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  attendance Attendance[]

  @@index([tenantId, date])
  @@index([tenantId, teacherId, startAt])
  @@index([tenantId, roomId, startAt])
  @@index([tenantId, groupId, startAt])
  @@map("lessons")
}

model Attendance {
  id        String   @id @default(uuid())
  tenantId  String
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    String // present|absent|late|excused
  note      String?
  markedAt  DateTime @default(now())

  @@unique([lessonId, studentId])
  @@index([tenantId, studentId])
  @@map("attendance")
}

model Exam {
  id        String   @id @default(uuid())
  tenantId  String
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  type      String   @default("exam") // exam|quiz|midterm|final
  date      DateTime @db.Date
  maxScore  Int      @default(100)
  weight    Int      @default(100) // percent
  createdAt DateTime @default(now())

  results ExamResult[]

  @@index([tenantId, groupId])
  @@map("exams")
}

model ExamResult {
  id        String  @id @default(uuid())
  tenantId  String
  examId    String
  exam      Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score     Int
  comment   String?

  @@unique([examId, studentId])
  @@index([tenantId, studentId])
  @@map("exam_results")
}

// ============ CRM (tenant-scoped) ============

model LeadStage {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  order    Int     @default(0)
  color    String  @default("#4F46E5")
  isWon    Boolean @default(false)
  isLost   Boolean @default(false)

  leads Lead[]

  @@index([tenantId, order])
  @@map("lead_stages")
}

model LeadSource {
  id       String @id @default(uuid())
  tenantId String
  name     String

  leads Lead[]

  @@index([tenantId])
  @@map("lead_sources")
}

model Lead {
  id                 String      @id @default(uuid())
  tenantId           String
  leadNo             Int? // per-tenant sequence, shown as #312
  name               String
  fullName           String?
  phone              String?
  email              String?
  instagram          String?
  age                Int?
  gender             String? // kisi|qadin|diger
  city               String?
  educationStatus    String?
  currentField       String?
  sourceId           String?
  source             LeadSource? @relation(fields: [sourceId], references: [id])
  sourceKey          String? // instagram_dm|whatsapp|telefon|referans|website|event|organic|paid_ads|tiktok
  campaignId         String? // marketing campaign attribution
  stageId            String
  stage              LeadStage   @relation(fields: [stageId], references: [id])
  status             String      @default("yeni_lead") // 14-value CRM status
  priority           String      @default("cold") // hot|warm|cold (auto)
  score              Int         @default(0) // 0-100 (auto)
  askedDemo          Boolean     @default(false)
  askedPrice         Boolean     @default(false)
  callAnswered       Boolean     @default(false)
  parentInvolved     Boolean     @default(false)
  budgetOk           Boolean     @default(false)
  notResponding      Boolean     @default(false)
  passive7d          Boolean     @default(false)
  ownerId            String?
  assignedTo         String?
  closedBy           String?
  createdBy          String?
  courseInterestId   String? // interested training/course
  value              Int? // expected value, minor units
  branchId           String?
  followupCount      Int         @default(0)
  lastContactAt      DateTime?
  nextFollowupAt     DateTime?
  lostReason         String?
  objectionReason    String?
  convertedStudentId String?
  utm                Json        @default("{}")
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?

  activities LeadActivity[]
  followups  Followup[]

  @@index([tenantId, stageId])
  @@index([tenantId, ownerId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, assignedTo])
  @@index([tenantId, phone])
  @@index([tenantId, nextFollowupAt])
  @@index([tenantId, createdAt])
  @@map("leads")
}

model LeadActivity {
  id          String    @id @default(uuid())
  tenantId    String
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        String // created|status_changed|followup|call|demo_scheduled|demo_done|payment|registration|note
  title       String?
  body        String? // description
  meta        Json      @default("{}")
  dueAt       DateTime?
  doneAt      DateTime?
  userId      String?
  createdAt   DateTime  @default(now())

  @@index([tenantId, leadId])
  @@map("lead_activities")
}

model Followup {
  id        String    @id @default(uuid())
  tenantId  String
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dueAt     DateTime
  doneAt    DateTime?
  isDone    Boolean   @default(false)
  note      String?
  createdBy String?
  createdAt DateTime  @default(now())

  @@index([tenantId, leadId])
  @@index([tenantId, isDone, dueAt])
  @@map("followups")
}

model Task {
  id          String    @id @default(uuid())
  tenantId    String
  title       String
  body        String?
  leadId      String?
  assigneeId  String?
  dueAt       DateTime?
  priority    String    @default("medium") // low|medium|high|urgent
  status      String    @default("todo") // todo|in_progress|done|cancelled
  entityType  String?
  entityId    String?
  createdBy   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId, assigneeId, status])
  @@index([tenantId, leadId])
  @@map("tasks")
}

// ============ FINANCE (tenant-scoped) ============

model CashAccount {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  type      String    @default("cash") // cash|bank|online
  branchId  String?
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  payments     Payment[]
  transactions Transaction[]
  expenses     Expense[]

  @@index([tenantId])
  @@map("cash_accounts")
}

model Invoice {
  id         String    @id @default(uuid())
  tenantId   String
  studentId  String
  groupId    String?
  number     String
  amount     Int
  discount   Int       @default(0)
  total      Int
  currency   String    @default("AZN")
  status     String    @default("open") // draft|open|partial|paid|overdue|void
  dueAt      DateTime
  periodFrom DateTime? @db.Date
  periodTo   DateTime? @db.Date
  note       String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  payments Payment[]

  @@unique([tenantId, number])
  @@index([tenantId, status, dueAt])
  @@index([tenantId, studentId])
  @@map("invoices")
}

model Payment {
  id             String      @id @default(uuid())
  tenantId       String
  invoiceId      String?
  invoice        Invoice?    @relation(fields: [invoiceId], references: [id])
  studentId      String
  cashAccountId  String
  cashAccount    CashAccount @relation(fields: [cashAccountId], references: [id])
  method         String // cash|card|transfer|online
  amount         Int
  currency       String      @default("AZN")
  paidAt         DateTime    @default(now())
  reference      String?
  idempotencyKey String?
  receivedById   String?
  refundedAmount Int         @default(0)
  createdAt      DateTime    @default(now())

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, studentId])
  @@index([tenantId, paidAt])
  @@map("payments")
}

model ExpenseCategory {
  id       String @id @default(uuid())
  tenantId String
  name     String

  expenses Expense[]

  @@index([tenantId])
  @@map("expense_categories")
}

model Expense {
  id            String          @id @default(uuid())
  tenantId      String
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  cashAccountId String
  cashAccount   CashAccount     @relation(fields: [cashAccountId], references: [id])
  amount        Int
  currency      String          @default("AZN")
  date          DateTime        @db.Date
  recurring     Boolean         @default(false) // true = monthly recurring, false = one-time
  vendor        String?
  note          String?
  branchId      String?
  createdById   String?
  createdAt     DateTime        @default(now())

  @@index([tenantId, date])
  @@map("expenses")
}

model Transaction {
  id            String      @id @default(uuid())
  tenantId      String
  cashAccountId String
  cashAccount   CashAccount @relation(fields: [cashAccountId], references: [id])
  type          String // income|expense|transfer_in|transfer_out|payroll|refund
  amount        Int // signed by type semantics; stored positive
  currency      String      @default("AZN")
  category      String?
  entityType    String?
  entityId      String?
  date          DateTime    @default(now())
  note          String?

  @@index([tenantId, cashAccountId, date])
  @@index([tenantId, type, date])
  @@map("transactions")
}

model PayrollRun {
  id        String   @id @default(uuid())
  tenantId  String
  period    String // "2026-07"
  status    String   @default("draft") // draft|approved|paid
  total     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PayrollItem[]

  @@unique([tenantId, period])
  @@map("payroll_runs")
}

model PayrollItem {
  id        String     @id @default(uuid())
  tenantId  String
  runId     String
  run       PayrollRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  teacherId String?
  userId    String?
  base      Int        @default(0)
  lessonPay Int        @default(0)
  bonus     Int        @default(0)
  deduction Int        @default(0)
  total     Int        @default(0)
  detail    Json       @default("{}")

  @@index([tenantId, runId])
  @@map("payroll_items")
}

// ============ MARKETING (tenant-scoped) ============

model Campaign {
  id          String    @id @default(uuid())
  tenantId    String
  name        String
  channel     String // meta|google|tiktok|instagram|offline|other
  budget      Int       @default(0)
  startAt     DateTime  @db.Date
  endAt       DateTime? @db.Date
  utmCampaign String?
  status      String    @default("active") // active|paused|finished
  createdAt   DateTime  @default(now())

  adSpends AdSpend[]

  @@index([tenantId, status])
  @@map("campaigns")
}

model AdSpend {
  id         String    @id @default(uuid())
  tenantId   String
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  channel    String
  amount     Int
  date       DateTime  @db.Date
  note       String?

  @@index([tenantId, date])
  @@map("ad_spends")
}

// ============ HR (tenant-scoped) ============

model Employee {
  id           String    @id @default(uuid())
  tenantId     String
  userId       String    @unique
  position     String?
  contractType String? // full_time|part_time|contract
  branchId     String?
  salaryQepik  Int       @default(0)
  hiredAt      DateTime? @db.Date
  firedAt      DateTime? @db.Date
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  leaveRequests LeaveRequest[]

  @@index([tenantId])
  @@map("employees")
}

model LeaveRequest {
  id         String    @id @default(uuid())
  tenantId   String
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fromDate   DateTime  @db.Date
  toDate     DateTime  @db.Date
  type       String // vacation|sick|unpaid|other
  reason     String?
  status     String    @default("pending") // pending|approved|rejected
  approverId String?
  decidedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("leave_requests")
}

// ============ INTEGRATIONS & WEBHOOKS (tenant-scoped) ============

model TenantIntegration {
  id             String    @id @default(uuid())
  tenantId       String
  catalogKey     String // matches integration_catalog.key
  status         String    @default("connected") // connected|disconnected|error
  config         Json      @default("{}")
  credentialsEnc String? // AES-256-GCM encrypted blob (iv:tag:ciphertext)
  connectedById  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([tenantId, catalogKey])
  @@map("tenant_integrations")
}

model WebhookEndpoint {
  id        String   @id @default(uuid())
  tenantId  String
  url       String
  secret    String // HMAC signing secret
  events    String[] // subscribed event keys
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  deliveries WebhookDelivery[]

  @@index([tenantId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id         String          @id @default(uuid())
  tenantId   String
  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event      String
  payload    Json
  status     String          @default("pending") // pending|success|failed
  attempts   Int             @default(0)
  lastError  String?
  createdAt  DateTime        @default(now())

  @@index([tenantId, endpointId])
  @@map("webhook_deliveries")
}

// ============ Instagram comment automation (tenant-scoped) ============

/// A rule: when a comment matching `keywords` lands on `mediaId` (or any post
/// when null), post `publicReply` under it and/or DM `dmMessage` to the author.
model InstagramAutomation {
  id            String    @id @default(uuid())
  tenantId      String
  name          String
  mediaId       String? // null = applies to every post
  mediaCaption  String? // cached caption/label for the UI
  keywords      String[]  @default([]) // empty = any comment
  publicReply   String? // posted as a reply under the comment
  dmMessage     String? // private reply (DM) to the commenter
  enabled       Boolean   @default(true)
  matchCount    Int       @default(0)
  lastMatchedAt DateTime?
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, mediaId])
  @@map("instagram_automations")
}

/// One row per comment we have acted on — the unique (tenant, commentId) key is
/// what stops us replying twice when polling overlaps or a webhook retries.
model InstagramCommentEvent {
  id            String   @id @default(uuid())
  tenantId      String
  commentId     String
  mediaId       String?
  automationId  String?
  fromUsername  String?
  text          String?
  repliedPublic Boolean  @default(false)
  sentDm        Boolean  @default(false)
  error         String?
  createdAt     DateTime @default(now())

  @@unique([tenantId, commentId])
  @@index([tenantId, automationId])
  @@map("instagram_comment_events")
}

// ============ AI (tenant-scoped) ============

model AiConversation {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  title     String   @default("Yeni söhbət")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AiMessage[]

  @@index([tenantId, userId])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(uuid())
  tenantId       String
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // user|assistant
  content        String
  toolCalls      Json?
  createdAt      DateTime       @default(now())

  @@index([tenantId, conversationId])
  @@map("ai_messages")
}

model AiUsageLog {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  model        String?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("ai_usage_log")
}

// ============ SYSTEM (tenant-scoped) ============

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String // create|update|delete|login|export|...
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, createdAt])
  @@index([tenantId, userId, createdAt])
  @@map("audit_log")
}

model File {
  id           String   @id @default(uuid())
  tenantId     String
  key          String   @unique
  name         String
  mime         String
  size         Int
  entityType   String?
  entityId     String?
  uploadedById String?
  createdAt    DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@map("files")
}

model Notification {
  id         String    @id @default(uuid())
  tenantId   String
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  title      String
  body       String?
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId, userId, readAt])
  @@map("notifications")
}

model MessageTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  key       String
  channel   String // email|sms
  subject   String?
  body      String
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key, channel])
  @@map("message_templates")
}

model MessageLog {
  id         String   @id @default(uuid())
  tenantId   String
  channel    String // email|sms
  recipient  String
  subject    String?
  body       String
  status     String   @default("sent") // sent|failed
  error      String?
  entityType String? // student|lead
  entityId   String?
  sentById   String?
  createdAt  DateTime @default(now())

  @@index([tenantId, channel, createdAt])
  @@map("message_logs")
}

model SavedFilter {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  entity    String // students|leads|invoices|...
  name      String
  filters   Json
  isShared  Boolean  @default(false)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId, entity])
  @@map("saved_filters")
}
